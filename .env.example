ENVIRONMENT=DEV
HOST_PROJECT_DIR=           # PROJECT DIRECTORY ON HOST (NOT IN A CONTAINER)!!!
DATA_SOURCE_URI=https://query1.finance.yahoo.com/v8/finance/chart/{ticker}?period1=0&period2=9999999999&interval=1d
# US Treasury daily par yield curve (constant maturity) — keyless public CSV, one file per year
TREASURY_YIELDS_URI=https://home.treasury.gov/resource-center/data-chart-center/interest-rates/daily-treasury-rates.csv/{year}/all?type=daily_treasury_yield_curve&field_tdr_date_value={year}&page&_format=csv
# Local DuckDB warehouse the yields query service reads (defaults to datalake path)
YIELD_WAREHOUSE_DB=/project/datalake/YIELD_DATA/yield_warehouse.duckdb
# NATS event bus for the yields serving tier (treasury.yields.ingested -> SSE)
NATS_URL=nats://nats:4222
# Frontend origin allowed by the API gateway (CORS)
FRONTEND_ORIGIN=http://localhost:5173
# Frontend (Vite dev server) host port + the gateway base URL the browser calls
FRONTEND_PORT=5173
VITE_API_BASE=http://localhost:8090/api/yields
# Host-published ports for the local Temporal dev server. Override only if
# another local Temporal already binds 7233/8233 (the in-compose worker always
# uses the internal 7233 via the `temporal` service name).
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8233
# Host-published ports for direct access. Override only on clashes; inter-service
# traffic uses the compose network regardless. Airflow UI + yields query API.
AIRFLOW_PORT=8080
YIELDS_QUERY_PORT=8000
AIRFLOW_HOME=/project/airflow
AIRFLOW_UID=1001
AIRFLOW_GID=0
AIRFLOW__DAG_PROCESSOR__REFRESH_INTERVAL=5

SNOWFLAKE_ACCOUNT=XXXXXXX-XX11111
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=MARKETS
SNOWFLAKE_SCHEMA=DEV

SNOWFLAKE_ADMIN_USER=admin
SNOWFLAKE_ADMIN_PASSWORD=password

SNOWFLAKE_HOME=/project/snowflake
SNOWFLAKE_USER=dbt
SNOWFLAKE_PRIVATE_KEY_FILE=/project/dbt/.credentials/rsa_key.p8
SNOWFLAKE_PUBLIC_KEY_FILE=/project/dbt/.credentials/rsa_key.pub
SNOWFLAKE_PRIVATE_KEY_FILE_PWD=password

PYSPARK_USER=pyspark
PYSPARK_PRIVATE_KEY_FILE=/project/src/.credentials/rsa_key.p8
PYSPARK_PUBLIC_KEY_FILE=/project/src/.credentials/rsa_key.pub
PYSPARK_PRIVATE_KEY_FILE_PWD=password
